<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Grading System</title>
    <style>
        body { font-family: sans-serif; margin: 40px; background-color: #f4f4f9; }
        .container { max-width: 400px; background: white; padding: 25px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input { width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        button { width: 100%; padding: 10px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; }
        button:hover { background-color: #0056b3; }
        .error { color: #dc3545; font-size: 14px; margin-top: 5px; min-height: 18px; }
        .result { margin-top: 20px; padding: 15px; background: #e9ecef; border-left: 5px solid #28a745; display: none; border-radius: 4px; }
    </style>
</head>
<body>

<div class="container">
    <h2>Student Grading System</h2>
    
    <form id="gradingForm">
        <div class="form-group">
            <label for="studentMarks">Enter Marks (0 - 100):</label>
            <input type="number" id="studentMarks" placeholder="e.g., 85">
            <div id="errorMessage" class="error"></div>
        </div>
        <button type="submit">Calculate Grade</button>
    </form>

    <div id="resultBox" class="result">
        <strong>Result:</strong> <span id="gradeOutput"></span>
    </div>
</div>

<script>
document.getElementById('gradingForm').addEventListener('submit', function(event) {
    // 1. Prevent form from refreshing the page
    event.preventDefault(); 
    
    // 2. Fetch DOM elements
    const marksInput = document.getElementById('studentMarks').value.trim();
    const errorDiv = document.getElementById('errorMessage');
    const resultBox = document.getElementById('resultBox');
    const gradeOutput = document.getElementById('gradeOutput');
    
    // Reset previous views
    errorDiv.textContent = "";
    resultBox.style.display = "none";

    // 3. Form Validation (Control Structure: if/else)
    if (marksInput === "") {
        errorDiv.textContent = "Please enter a mark.";
        return;
    }

    const marks = Number(marksInput);

    if (isNaN(marks)) {
        errorDiv.textContent = "Please enter a valid numeric value.";
        return;
    }
    if (marks < 0 || marks > 100) {
        errorDiv.textContent = "Marks must be between 0 and 100.";
        return;
    }

    // 4. Determine Grade (Control Structure: if / else if / else)
    let grade = "";
    if (marks >= 90) {
        grade = "A";
    } else if (marks >= 80) {
        grade = "B";
    } else if (marks >= 70) {
        grade = "C";
    } else if (marks >= 60) {
        grade = "D";
    } else {
        grade = "F";
    }

    // 5. Generate Feedback (Control Structure: switch)
    let feedback = "";
    switch(grade) {
        case "A":
            feedback = "Excellent performance!";
            break;
        case "B":
            feedback = "Very good job!";
            break;
        case "C":
            feedback = "Good, but room for improvement.";
            break;
        case "D":
            feedback = "Passed, needs hard work.";
            break;
        case "F":
            feedback = "Failed. Please seek assistance.";
            break;
        default:
            feedback = "Invalid grade determined.";
    }

    // 6. Output the final result to the DOM
    gradeOutput.textContent = `Grade ${grade} — ${feedback}`;
    resultBox.style.display = "block";
});
</script>

</body>
</html>
